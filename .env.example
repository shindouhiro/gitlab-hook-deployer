GITLAB_WEBHOOK_SECRET=replace-with-your-secret
DEPLOY_BASE_DIR=./deploy_repos
DEPLOY_ALLOWED_BRANCHES=main,release/*

# 可选：在项目目录中执行的部署命令。
# DEPLOY_BUILD_CMD=pnpm install && pnpm build
# DEPLOY_RELEASE_CMD=docker compose up -d --build
# DEPLOY_HEALTHCHECK_CMD=curl -fsS http://127.0.0.1:3000/health

# 批量拉取与批量配置 Hook（scripts/gitlab_bulk_setup.py）
# 建议优先使用 GITLAB_TOKEN，账号密码仅作兼容方案。
GITLAB_BASE_URL=https://git.cloud2go.cn
# GITLAB_TOKEN=
# GITLAB_USERNAME=
# GITLAB_PASSWORD=
# GITLAB_VERIFY_SSL=true
# GITLAB_CA_CERT=/path/to/ca.pem
CLONE_BASE_DIR=./repositories
# HOOK_URL=http://127.0.0.1:8000/api/hook/gitlab
# HOOK_TOKEN=replace-with-your-secret
# HOOK_BRANCH_FILTER=main
# DRY_RUN=true
# INCLUDE_ARCHIVED=false
# SKIP_CLONE=false
# SKIP_HOOK=false
